{
  "name": "shoggoth",
  "version": "0.1.0",
  "private": true,
  "description": "Shoggoth agent orchestration platform",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rf packages/*/dist dist",
    "cli": "node --import tsx/esm packages/cli/src/cli.ts",
    "daemon": "node --import tsx/esm packages/daemon/src/index.ts",
    "reinstall": "rm -rf node_modules **/node_modules && npm ci",
    "test": "vitest run",
    "test:ci-agent-isolation": "SHOGGOTH_CI_STRICT_AGENT_TESTS=1 npx vitest run packages/os-exec",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "husky || true",
    "format": "oxfmt"
  },
  "dependencies": {
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "~22",
    "commitlint": "^20.5.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "~5.7.2",
    "vitest": "^4.1.2"
  },
  "nano-staged": {
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.ts": [
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": "~22"
  }
}
