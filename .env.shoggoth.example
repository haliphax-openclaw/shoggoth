# Shoggoth Docker stack environment (copy → `.env.shoggoth.local`, never commit).
#
# Discord: use a dedicated Shoggoth bot token — do not reuse another app’s bot if you intend separate policy.
# Model: set ANTHROPIC_* and/or OPENAI_* to an API reachable from the container (e.g. `host.docker.internal` for a server on the Docker host).

DISCORD_BOT_TOKEN=

# Guild channel → session URN (`agent:<agentId>:discord:<channelId>` with the same snowflake as `channelId`). Workspace dir is `{workspacesRoot}/{agentId}` (bootstrapMainSession).
SHOGGOTH_DISCORD_ROUTES=[{"guildId":"695327822306345040","channelId":"1487579255616573533","sessionId":"agent:main:discord:1487579255616573533"}]

# SHOGGOTH_DISCORD_OWNER_USER_ID=

# Logical agent id → workspace `/var/lib/shoggoth/workspaces/{id}` (must match URN segment after `agent:`).
# SHOGGOTH_AGENT_ID=main
# SHOGGOTH_DEFAULT_SESSION_PLATFORM=discord

ANTHROPIC_BASE_URL=http://host.docker.internal:8000
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=
ANTHROPIC_AUTH=
OPENAI_BASE_URL=
OPENAI_API_KEY=
# Optional memory embeddings (`memory.embeddings.enabled` in config): same vars unless overridden via `memory.embeddings.openaiBaseUrl` / `apiKeyEnv` or `SHOGGOTH_MEMORY_OPENAI_BASE_URL`.
# SHOGGOTH_MEMORY_OPENAI_BASE_URL=
SHOGGOTH_MODEL=claude-sonnet-4-20250514

SHOGGOTH_OPERATOR_TOKEN=readiness-ci-token

# Optional HITL operator ping: guild channel id, webhook URL, or Discord user snowflake for DM.
# SHOGGOTH_HITL_NOTIFY_CHANNEL_ID=
# SHOGGOTH_HITL_NOTIFY_WEBHOOK_URL=
# SHOGGOTH_HITL_NOTIFY_DM_USER_ID=
# In-thread HITL reply in the routed Discord channel (default on). Set 0 to disable; or use layered JSON `discord.hitlReplyInSession`.
# SHOGGOTH_DISCORD_HITL_REPLY_IN_SESSION=
