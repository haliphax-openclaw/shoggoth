# Shoggoth Docker stack environment (copy → `.env.shoggoth.local`, never commit).
#
# Discord: use a dedicated Shoggoth bot token — do not reuse OpenClaw’s bot.
# LM: tune to match `~/.openclaw/openclaw.json` (e.g. kiro / anthropic-messages). Readiness + kick-tires add `host.docker.internal` → host gateway.
# Kick-tires (`scripts/kick-tires-up.sh`) attaches the `proxy` network automatically. For `docker compose` with only `docker-compose.yml`, add `-f docker-compose.proxy-network.yml` if LM is on `kiro` / `proxy`.

DISCORD_BOT_TOKEN=

# Guild channel → session URN (`agent:<agentId>:discord:<channelId>` with the same snowflake as `channelId`). Workspace dir is `{workspacesRoot}/{agentId}` (bootstrap-main-session). For #developer use channelId 1480957862858719232.
SHOGGOTH_DISCORD_ROUTES=[{"guildId":"695327822306345040","channelId":"1487579255616573533","sessionId":"agent:main:discord:1487579255616573533"}]

# Operator Discord user snowflake (recommended for v1). When set, only this user’s channel messages are sent to the model; others are dropped silently. Same as layered `discord.ownerUserId`.
# SHOGGOTH_DISCORD_OWNER_USER_ID=

# Logical agent id → workspace `/var/lib/shoggoth/workspaces/{id}` (must match URN segment after `agent:`).
# If a route uses reserved session UUID 00000000-0000-4000-8000-000000000001, the URN must match SHOGGOTH_AGENT_ID + SHOGGOTH_DEFAULT_SESSION_PLATFORM or Discord startup fails (guard). Snowflake session ids must equal `channelId` when both are numeric Discord ids.
# SHOGGOTH_AGENT_ID=main
# SHOGGOTH_DEFAULT_SESSION_PLATFORM=discord

ANTHROPIC_BASE_URL=http://host.docker.internal:8000
ANTHROPIC_API_KEY=openclaw
ANTHROPIC_VERSION=
ANTHROPIC_AUTH=
OPENAI_BASE_URL=
OPENAI_API_KEY=
# Optional memory embeddings (`memory.embeddings.enabled` in config): same vars unless overridden via `memory.embeddings.openaiBaseUrl` / `apiKeyEnv` or `SHOGGOTH_MEMORY_OPENAI_BASE_URL`.
# SHOGGOTH_MEMORY_OPENAI_BASE_URL=
SHOGGOTH_MODEL=kiro/auto

SHOGGOTH_OPERATOR_TOKEN=shoggoth-kick-operator-token

# Optional HITL operator ping: guild channel id, webhook URL, or Discord user snowflake for DM (`docker-compose.kick-tires.yml` sets DM for haliphax by default).
# SHOGGOTH_HITL_NOTIFY_CHANNEL_ID=
# SHOGGOTH_HITL_NOTIFY_WEBHOOK_URL=
# SHOGGOTH_HITL_NOTIFY_DM_USER_ID=
# In-thread HITL reply in the routed Discord channel (default on). Kick-tires sets 0; or use layered JSON `discord.hitlReplyInSession`.
# SHOGGOTH_DISCORD_HITL_REPLY_IN_SESSION=
