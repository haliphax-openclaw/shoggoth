    "@shoggoth/os-exec": "*",
    "@shoggoth/authn": "*",
    "@shoggoth/models": "*",
    "@shoggoth/shared": "*",
    "@shoggoth/skills-plugins": "*",
    "better-sqlite3": "^11.7.0",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  }
}
